// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
  pages     Page[]
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     Json      // TipTap JSON blocks
  excerpt     String?
  coverImage  String?   // URL to Uploadthing
  status      Status    @default(DRAFT)
  seoTitle    String?
  seoDesc     String?
  ogImage     String?
  author      User      @relation(fields: [authorId], references: [id])
  authorId    String
  categories  Category[]
  tags        Tag[]
  heroBgColor     String?            // CSS color for hero background, e.g. "#4ade80"
  heroBgImage     String?            // URL of hero background image
  publishedAt     DateTime?
  previewToken    String?   @unique  // null = sharing disabled; UUID generated on demand
  previewPassword String?            // plaintext; low-security gating only
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   Json     // TipTap JSON blocks
  status    Status   @default(DRAFT)
  seoTitle  String?
  seoDesc   String?
  ogImage   String?
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  userEmail   String
  action      String   // "CREATE" | "UPDATE" | "DELETE"
  entityType  String   // "POST" | "MEDIA"
  entityId    String
  entityTitle String
  createdAt   DateTime @default(now())
}
